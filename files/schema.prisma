// prisma/schema.prisma
// Car Hire Mauritius — Complete Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
  BRANCH_STAFF
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  REFUNDED
  FAILED
}

enum CarStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RETIRED
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum CarCategory {
  ECONOMY
  COMPACT
  MIDSIZE
  SUV
  LUXURY
  SPORTS
  VAN
  CONVERTIBLE
}

// ─────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  name            String?
  phone           String?
  avatar          String?
  role            UserRole  @default(CUSTOMER)
  isBlacklisted   Boolean   @default(false)
  isVIP           Boolean   @default(false)
  loyaltyPoints   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  bookings        Booking[]
  reviews         Review[]
  documents       Document[]
  notes           CustomerNote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// CAR FLEET
// ─────────────────────────────────────────

model Car {
  id               String       @id @default(cuid())
  slug             String       @unique
  make             String       // e.g. Toyota
  model            String       // e.g. Yaris
  year             Int
  category         CarCategory
  status           CarStatus    @default(AVAILABLE)
  
  // Specs
  seats            Int
  doors            Int
  luggage          Int          // number of bags
  fuelType         FuelType
  transmission     Transmission
  engineCC         Int?
  mileagePerDay    Int?         // km allowed per day
  
  // Pricing (base rates in MUR)
  pricePerDay      Float        // MUR
  pricePerWeek     Float        // MUR (7 days)
  priceDeposit     Float        // MUR security deposit
  
  // Media
  images           CarImage[]
  thumbnailUrl     String?
  
  // Features
  features         String[]     // ["AC", "GPS", "Bluetooth", "Baby Seat available"]
  description      String?      @db.Text
  
  // Meta
  plateNumber      String?      @unique
  color            String?
  branchId         String?
  branch           Branch?      @relation(fields: [branchId], references: [id])
  
  bookings         Booking[]
  reviews          Review[]
  maintenanceLogs  MaintenanceLog[]
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model CarImage {
  id        String   @id @default(cuid())
  carId     String
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────

model Booking {
  id               String        @id @default(cuid())
  bookingRef       String        @unique  // e.g. CHM-2024-00142
  userId           String?
  user             User?         @relation(fields: [userId], references: [id])
  carId            String
  car              Car           @relation(fields: [carId], references: [id])
  
  // Dates
  pickupDate       DateTime
  returnDate       DateTime
  totalDays        Int
  
  // Locations
  pickupLocation   String
  returnLocation   String
  pickupLocationId String?
  returnLocationId String?
  
  // Pricing breakdown
  basePrice        Float         // before addons/discounts
  addonsPrice      Float         @default(0)
  discountAmount   Float         @default(0)
  taxAmount        Float         @default(0)
  depositAmount    Float         @default(0)
  totalPrice       Float
  currency         String        @default("MUR")
  
  // Status
  status           BookingStatus @default(PENDING)
  paymentStatus    PaymentStatus @default(PENDING)
  
  // Driver info (guest or override)
  driverName       String?
  driverEmail      String?
  driverPhone      String?
  driverLicense    String?
  driverAge        Int?
  
  // Extras
  couponCode       String?
  specialRequests  String?       @db.Text
  internalNotes    String?       @db.Text
  
  // Add-ons selected
  addons           BookingAddon[]
  payments         Payment[]
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model BookingAddon {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])
  addonId   String
  addon     Addon   @relation(fields: [addonId], references: [id])
  quantity  Int     @default(1)
  price     Float   // price at time of booking
}

// ─────────────────────────────────────────
// ADD-ONS
// ─────────────────────────────────────────

model Addon {
  id          String  @id @default(cuid())
  name        String
  description String?
  icon        String? // lucide icon name
  priceType   String  // "per_day" | "per_booking" | "per_item"
  price       Float   // MUR
  maxQuantity Int     @default(1)
  isActive    Boolean @default(true)
  
  bookings    BookingAddon[]
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id])
  amount          Float
  currency        String        @default("MUR")
  provider        String        // "stripe" | "razorpay" | "cash"
  providerTxId    String?       // Stripe payment intent ID
  status          PaymentStatus @default(PENDING)
  type            String        @default("full") // "full" | "deposit" | "balance" | "refund"
  metadata        Json?
  createdAt       DateTime      @default(now())
}

// ─────────────────────────────────────────
// PRICING RULES
// ─────────────────────────────────────────

model PricingRule {
  id          String   @id @default(cuid())
  name        String
  type        String   // "seasonal" | "surge" | "duration" | "category"
  category    CarCategory?
  startDate   DateTime?
  endDate     DateTime?
  multiplier  Float    // e.g. 1.3 = 30% increase
  minDays     Int?
  maxDays     Int?
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  type          String   // "percentage" | "fixed"
  value         Float    // % or MUR amount
  minBookingVal Float?
  maxUses       Int?
  usedCount     Int      @default(0)
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ─────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  carId      String
  car        Car      @relation(fields: [carId], references: [id])
  rating     Int      // 1-5
  title      String?
  body       String?  @db.Text
  isVerified Boolean  @default(false)
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────
// LOCATIONS / BRANCHES
// ─────────────────────────────────────────

model Location {
  id        String  @id @default(cuid())
  name      String
  address   String
  type      String  // "airport" | "city" | "hotel" | "port"
  lat       Float?
  lng       Float?
  isActive  Boolean @default(true)
}

model Branch {
  id       String  @id @default(cuid())
  name     String
  address  String
  phone    String?
  email    String?
  isActive Boolean @default(true)
  cars     Car[]
}

// ─────────────────────────────────────────
// DOCUMENTS
// ─────────────────────────────────────────

model Document {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  type       String   // "license" | "passport" | "id_card"
  url        String
  expiresAt  DateTime?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────
// MAINTENANCE
// ─────────────────────────────────────────

model MaintenanceLog {
  id          String   @id @default(cuid())
  carId       String
  car         Car      @relation(fields: [carId], references: [id])
  type        String   // "service" | "repair" | "inspection"
  description String?
  cost        Float?
  date        DateTime
  nextDueDate DateTime?
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ip        String?
  createdAt DateTime @default(now())
}

model CustomerNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  note      String   @db.Text
  createdBy String
  createdAt DateTime @default(now())
}
