{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information for customers",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "full_name": { "type": "string" },
        "phone": { "type": "string" },
        "date_of_birth": { "type": "string", "format": "date" },
        "nationality": { "type": "string" },
        "passport_number": { "type": "string" },
        "licence_number": { "type": "string" },
        "licence_country": { "type": "string" },
        "licence_expiry": { "type": "string", "format": "date" },
        "years_driving": { "type": "number" },
        "marketing_opt_in": { "type": "boolean" },
        "blacklisted": { "type": "boolean" },
        "blacklist_reason": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "AdminUser": {
      "title": "AdminUser",
      "description": "Administrative users with roles",
      "type": "object",
      "properties": {
        "auth_user_id": { "type": "string" },
        "full_name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super", "manager", "staff"] },
        "active": { "type": "boolean" },
        "last_login": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Car": {
      "title": "Car",
      "description": "Vehicle details",
      "type": "object",
      "properties": {
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "colour": { "type": "string" },
        "registration_plate": { "type": "string" },
        "slug": { "type": "string" },
        "category_id": { "type": "string" },
        "transmission": { "type": "string", "enum": ["automatic", "manual"] },
        "fuel_type": { "type": "string" },
        "engine_size": { "type": "string" },
        "seats": { "type": "number" },
        "doors": { "type": "number" },
        "boot_litres": { "type": "number" },
        "base_price_per_day": { "type": "number" },
        "min_rental_days": { "type": "number" },
        "deposit_amount": { "type": "number" },
        "insurance_category": { "type": "string" },
        "description": { "type": "string" },
        "active": { "type": "boolean" },
        "featured": { "type": "boolean" },
        "sort_order": { "type": "number" },
        "min_driver_age": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["make", "model", "slug", "base_price_per_day"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Car rental booking record",
      "type": "object",
      "properties": {
        "ref_number": { "type": "string" },
        "customer_id": { "type": "string" },
        "car_id": { "type": "string" },
        "pickup_location_id": { "type": "string" },
        "return_location_id": { "type": "string" },
        "pickup_datetime": { "type": "string", "format": "date-time" },
        "return_datetime": { "type": "string", "format": "date-time" },
        "total_days": { "type": "number" },
        "base_price": { "type": "number" },
        "addons_total": { "type": "number" },
        "surcharges_total": { "type": "number" },
        "discount_amount": { "type": "number" },
        "discount_reason": { "type": "string" },
        "grand_total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "active", "completed", "cancelled", "no_show"] },
        "payment_method": { "type": "string", "enum": ["online", "on_arrival", "bank_transfer"] },
        "payment_status": { "type": "string", "enum": ["unpaid", "paid", "partially_paid", "refunded"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["ref_number", "customer_id", "car_id", "grand_total", "status"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "Customer profiles"
    },
    "/admin_users/{adminId}": {
      "schema": "AdminUser",
      "description": "Admin users"
    },
    "/cars/{carId}": {
      "schema": "Car",
      "description": "Fleet of cars"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Rental bookings"
    }
  }
}
