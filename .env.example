# Supabase Postgres connection used by Prisma at runtime
# Use the pooled connection string from Supabase for app traffic
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=10&schema=public"

# Direct database connection used by Prisma migrations/db push
# Use the non-pooled connection string from Supabase
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?schema=public"

# Optional Supabase client keys if you later add Supabase auth/storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# NextAuth (Optional, for Admin Login)
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Future Keys (Stripe, Resend, Maps)
STRIPE_SECRET_KEY=""
RESEND_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
